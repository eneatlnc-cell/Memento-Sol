<shortcuts xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <capability
        android:name="custom.actions.intent.ASK_MYAGENT"
        app:queryPatterns="@array/ask_myagent_query_patterns">
        <intent
            android:action="com.myagent.app.action.ASK_MYAGENT"
            android:targetPackage="com.myagent.app"
            android:targetClass="com.myagent.app.MainActivity">
            <parameter
                android:name="prompt"
                android:key="prompt"
                android:mimeType="https://schema.org/Text"
                android:required="true" />
        </intent>
    </capability>
</shortcuts>